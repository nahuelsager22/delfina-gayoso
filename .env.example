# Sanity — proyecto de contenido (Bloque 8 · 14ª ola).
# Copiar este archivo como `.env.local`.

# Públicos: viajan al navegador (el Studio los necesita). No son secretos.
NEXT_PUBLIC_SANITY_PROJECT_ID=a7nwe5rn
NEXT_PUBLIC_SANITY_DATASET=production

# SECRETO: sólo lo usa el script de carga inicial (`pnpm sembrar`), nunca el sitio.
# Se crea en https://sanity.io/manage → proyecto → API → Tokens → permiso "Editor".
# NO subir este valor al repositorio.
SANITY_API_WRITE_TOKEN=
